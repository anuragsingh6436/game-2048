<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Numra Icon — Hero Tile (properly sized)
        Viewport: 108x108. Center: 54,54.
        Tile: 36x36dp → from (36,36) to (72,72)
        Generous margin for circle/squircle masks.
    -->

    <!-- Main tile — gold-to-amber gradient -->
    <path android:pathData="M44,36 L64,36 A8,8 0,0,1 72,44 L72,64 A8,8 0,0,1 64,72 L44,72 A8,8 0,0,1 36,64 L36,44 A8,8 0,0,1 44,36 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="36"
                android:startY="36"
                android:endX="72"
                android:endY="72">
                <item android:color="#FFF9D872" android:offset="0.0" />
                <item android:color="#FFEE9A30" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glass frost — top portion -->
    <path android:pathData="M44,36 L64,36 A8,8 0,0,1 72,44 L72,48 L36,48 L36,44 A8,8 0,0,1 44,36 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54"
                android:startY="36"
                android:endX="54"
                android:endY="48">
                <item android:color="#2AFFFFFF" android:offset="0.0" />
                <item android:color="#00FFFFFF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Bottom shadow -->
    <path android:pathData="M36,64 L72,64 L72,64 A8,8 0,0,1 64,72 L44,72 A8,8 0,0,1 36,64 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54"
                android:startY="64"
                android:endX="54"
                android:endY="72">
                <item android:color="#00000000" android:offset="0.0" />
                <item android:color="#15000000" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
