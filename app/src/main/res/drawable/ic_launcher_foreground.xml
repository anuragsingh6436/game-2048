                android:startX="26"
                android:startY="28"
                android:endX="52"
                android:endY="54">
                <item android:color="#FFF2C94C" android:offset="0.0" />
                <item android:color="#FFED8A5A" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Top-right tile (warm taupe) -->
    <path android:pathData="M58,28 L80,28 Q82,28 82,30 L82,52 Q82,54 80,54 L58,54 Q56,54 56,52 L56,30 Q56,28 58,28 Z"
        android:fillColor="#FFC2B5A7" />

    <!-- Bottom-left tile (warm taupe) -->
    <path android:pathData="M28,58 L50,58 Q52,58 52,60 L52,80 Q52,82 50,82 L28,82 Q26,82 26,80 L26,60 Q26,58 28,58 Z"
        android:fillColor="#FFC2B5A7" />

    <!-- Bottom-right tile (amber — about to merge) -->
    <path android:pathData="M58,58 L80,58 Q82,58 82,60 L82,80 Q82,82 80,82 L58,82 Q56,82 56,80 L56,60 Q56,58 58,58 Z">
        <aapt:attr name="android:fillColor">
