<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Numra Icon — Hero Tile
        Viewport: 108x108. Safe zone: center 72x72 (18→90).
        Tile: 44x44dp centered at (54,54) with 10dp radius.
        Leaves 14dp margin inside safe zone on each side.
    -->

    <!-- Main tile — gold-to-amber gradient -->
    <path android:pathData="M32,32 h44 a10,10 0,0,1 10,10 v44 a10,10 0,0,1 -10,10 h-44 a10,10 0,0,1 -10,-10 v-44 a10,10 0,0,1 10,-10 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="22"
                android:startY="32"
                android:endX="86"
                android:endY="96">
                <item android:color="#FFF9D872" android:offset="0.0" />
                <item android:color="#FFEE9A30" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glass frost — top 30% of tile -->
    <path android:pathData="M32,32 h44 a10,10 0,0,1 10,10 v10 h-64 v-10 a10,10 0,0,1 10,-10 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54"
                android:startY="32"
                android:endX="54"
                android:endY="52">
                <item android:color="#30FFFFFF" android:offset="0.0" />
                <item android:color="#00FFFFFF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Bottom shadow -->
    <path android:pathData="M22,78 h64 v8 a10,10 0,0,1 -10,10 h-44 a10,10 0,0,1 -10,-10 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54"
                android:startY="78"
                android:endX="54"
                android:endY="96">
                <item android:color="#00000000" android:offset="0.0" />
                <item android:color="#18000000" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
