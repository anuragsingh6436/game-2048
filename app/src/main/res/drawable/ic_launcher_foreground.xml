                android:startX="56"
                android:startY="58"
                android:endX="82"
                android:endY="82">
                <item android:color="#FFEDCC61" android:offset="0.0" />
                <item android:color="#FFF2C94C" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Subtle "N" hint — diagonal connection between top-left and bottom-right -->
    <path
        android:pathData="M46,48 L62,62"
        android:strokeWidth="2.5"
        android:strokeColor="#30776E65"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />
